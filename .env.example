NODE_ENV=development

# Frontend apps must point to the Worker origin. In local development,
# wrangler dev uses http://127.0.0.1:8787 by default.
VITE_API_BASE_URL=http://127.0.0.1:8787
VITE_ADMIN_APP_URL=http://localhost:5174
VITE_PUBLIC_APP_URL=http://localhost:5173

# Keep web/admin/api under the same eTLD+1 in production so the admin
# session cookie remains same-site: blog.example.com / admin.example.com / api.example.com
PUBLIC_APP_ORIGIN=http://localhost:5173
ADMIN_APP_ORIGIN=http://localhost:5174
VITE_GA_MEASUREMENT_ID=

D1_DATABASE_ID=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
ADMIN_EMAIL=admin@example.com

# Use a SHA-256 hex digest or sha256:<hex>. Plaintext passwords are not supported.
ADMIN_PASSWORD_HASH=sha256:replace_with_sha256_hex
JWT_SECRET=replace_with_a_long_random_secret
